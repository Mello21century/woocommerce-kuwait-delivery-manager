#. Plugin Name of the plugin
#. Author of the plugin
msgid "Kuwait Delivery Manager"
msgstr "Kuwait Delivery Manager"

#. Plugin URI of the plugin
msgid "https://example.com/kuwait-delivery-manager"
msgstr "https://example.com/kuwait-delivery-manager"

#. Description of the plugin
msgid ""
"Manage Kuwait delivery areas and pricing from the WooCommerce admin "
"dashboard. Full bilingual (AR/EN) support, WooCommerce checkout integration, "
"inline editing, copy-to-all, WPML & Polylang compatible."
msgstr ""
"Manage Kuwait delivery areas and pricing from the WooCommerce admin "
"dashboard. Full bilingual (AR/EN) support, WooCommerce checkout integration, "
"inline editing, copy-to-all, WPML & Polylang compatible."

